# AgentHack environment placeholders

# App
NEXT_PUBLIC_APP_NAME=AgentHack
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Email (Resend / SMTP / Mailgun alternative)
RESEND_API_KEY=your_resend_api_key_here
FROM_EMAIL=events@clawhack.ai
FROM_NAME=AgentHack

# Calendar
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REFRESH_TOKEN=your_google_refresh_token
GOOGLE_CALENDAR_ID=primary
TIMEZONE=America/Los_Angeles

# GitHub
GITHUB_APP_ID=your_github_app_id
GITHUB_APP_INSTALLATION_ID=your_installation_id
GITHUB_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GITHUB_ORG=your_github_org

# Data (Supabase)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: LLM providers for review/feedback generation
OPENAI_API_KEY=your_openai_api_key
MODEL_FEEDBACK=gpt-4o-mini

# Google Sheet webhook (Apps Script web app URL)
NEXT_PUBLIC_GOOGLE_SHEET_WEBHOOK_URL=

# Ops automation
NEXT_PUBLIC_FOOD_ORDER_WEBHOOK_URL=
